# ============================================================
# ESCOLA SEIVA — Variáveis de Ambiente
# Copie para .env e preencha com seus valores reais
# ============================================================

# ── Banco de Dados (Supabase PostgreSQL) ──────────────────────
# Pegue no painel Supabase: Settings → Database → Connection string → URI
# Use a connection string com ?pgbouncer=true para produção
DATABASE_URL="postgresql://postgres:[SUA-SENHA]@db.[SEU-ID].supabase.co:5432/postgres"

# ── NextAuth.js ───────────────────────────────────────────────
NEXTAUTH_URL="https://teal-wombat-542968.hostingersite.com"
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="cole-aqui-uma-chave-aleatoria-forte-de-32-chars"

# ── Asaas (Pagamentos) ────────────────────────────────────────
# Sandbox (testes):
ASAAS_BASE_URL="https://sandbox.asaas.com/api/v3"
# Produção:
# ASAAS_BASE_URL="https://www.asaas.com/api/v3"

# Chave de API do painel Asaas (começa com $aact_)
ASAAS_API_KEY="$aact_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Segredo do Webhook (configure o mesmo no painel Asaas)
WEBHOOK_SECRET="seiva-webhook-segredo-forte-aqui"

# ── URL pública ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://teal-wombat-542968.hostingersite.com"
