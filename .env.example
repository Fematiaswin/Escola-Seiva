# ============================================================
# ESCOLA SEIVA — Variáveis de Ambiente
# Copie para .env e preencha com seus valores reais
# ============================================================

# ── Banco de Dados (Supabase PostgreSQL) ──────────────────────
# Use o pooler compartilhado em modo transação para produção/Vercel.
DATABASE_URL="postgresql://postgres.[SEU-ID]:[SUA-SENHA]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Use o pooler em modo sessão para comandos administrativos/migrations quando necessário.
DIRECT_URL="postgresql://postgres.[SEU-ID]:[SUA-SENHA]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# ── NextAuth.js ───────────────────────────────────────────────
NEXTAUTH_URL="https://teal-wombat-542968.hostingersite.com"
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="cole-aqui-uma-chave-aleatoria-forte-de-32-chars"

# ── Asaas (Pagamentos) ────────────────────────────────────────
# Sandbox (testes):
ASAAS_BASE_URL="https://sandbox.asaas.com/api/v3"
# Produção:
# ASAAS_BASE_URL="https://www.asaas.com/api/v3"

# Chave de API do painel Asaas (começa com $aact_)
ASAAS_API_KEY="$aact_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Segredo do Webhook (configure o mesmo no painel Asaas)
WEBHOOK_SECRET="seiva-webhook-segredo-forte-aqui"

# ── URL pública ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://teal-wombat-542968.hostingersite.com"

# ── Supabase Client (opcional; usado futuramente para Storage/API pública) ──
NEXT_PUBLIC_SUPABASE_URL="https://zuwgagvcvqszqavqridu.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
